{
  "name": "pulseops-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.vue",
    "test:unit": "vitest run --passWithNoTests --maxWorkers=1 --minWorkers=1 --no-file-parallelism"
  },
  "dependencies": {
    "@apollo/client": "^3.13.9",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/apollo-composable": "^4.2.2",
    "autoprefixer": "^10.4.21",
    "chart.js": "^4.4.9",
    "graphql": "^16.11.0",
    "graphql-ws": "^6.0.6",
    "pinia": "^3.0.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vue": "^3.5.14",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4",
    "vue-tsc": "^2.2.10"
  }
}
