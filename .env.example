# App
ENV=development
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173

# MongoDB
# replicaSet=rs0 is required for MongoDB Change Streams.
MONGODB_URI=mongodb://mongo:27017/pulseops?replicaSet=rs0
MONGODB_DB=pulseops

# Auth
JWT_SECRET=replace-with-32-char-random-string
JWT_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URL=http://localhost:8080/auth/callback

# Frontend (Vite)
# VITE_ is required for Vite to expose environment variables to the browser.
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/query
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Never create VITE_GOOGLE_CLIENT_SECRET. The Google client secret stays server-side only.
